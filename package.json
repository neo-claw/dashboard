    "lucide-react": "^0.378.0",
    "next": "^16.2.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.0",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^10.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.5.0"
