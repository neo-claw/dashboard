#!/usr/bin/env python3
import argparse
import json
import os
import sys
import time
import subprocess
import smtplib
from email.mime.text import MIMEText
from datetime import datetime

# Import core logic
from recreation_check import check_campground_availability, has_availability_changed

# Constants (default paths)
DEFAULT_LOG_FILE = os.path.expanduser("~/.openclaw/workspace/logs/recreation-check-notifications.log")
DEFAULT_CACHE_FILE = os.path.expanduser("~/.openclaw/workspace/cache/recreation-check-last-result.json")
DEFAULT_HEARTBEAT_FILE = os.path.expanduser("~/.openclaw/workspace/cache/recreation-check-heartbeat.json")

# Global variables for paths (may be overridden in test mode)
LOG_FILE = DEFAULT_LOG_FILE
CACHE_FILE = DEFAULT_CACHE_FILE
HEARTBEAT_FILE = DEFAULT_HEARTBEAT_FILE
TELEGRAM_MOCK_FILE = None
TEST_MODE = False
FORCE_MODE = False

def log(msg):
    print(f"[{datetime.utcnow().isoformat()}Z] {msg}", file=sys.stderr)

# Preset definitions
PRESETS = {
    "yosemite-valley": [
        {"id": 232447, "name": "Upper Pines"},
        {"id": 232450, "name": "North Pines"},
        {"id": 232448, "name": "Lower Pines"}
    ],
    "yosemite-all": [
        {"id": 232447, "name": "Upper Pines"},
        {"id": 232450, "name": "North Pines"},
        {"id": 232448, "name": "Lower Pines"},
        {"id": 232449, "name": "Yosemite Creek"},
        {"id": 232446, "name": "Camp 4"}
    ]
}

def send_email(subject, body, to_addr=None):
    """Send email via SMTP if configured."""
    smtp_host = os.environ.get('OPENCLAW_SMTP_HOST')
    smtp_port = os.environ.get('OPENCLAW_SMTP_PORT', '587')
    smtp_user = os.environ.get('OPENCLAW_SMTP_USER')
    smtp_pass = os.environ.get('OPENCLAW_SMTP_PASS')
    from_addr = os.environ.get('OPENCLAW_EMAIL_FROM', smtp_user)
    to_addr = to_addr or os.environ.get('OPENCLAW_EMAIL_TO', from_addr)

    if not all([smtp_host, smtp_port, smtp_user, smtp_pass]):
        log("SMTP not fully configured, skipping email")
        return False

    try:
        msg = MIMEText(body)
        msg['Subject'] = subject
        msg['From'] = from_addr
        msg['To'] = to_addr

        with smtplib.SMTP(smtp_host, int(smtp_port)) as server:
            server.starttls()
            server.login(smtp_user, smtp_pass)
            server.send_message(msg)
        log(f"Email sent to {to_addr}")
        return True
    except Exception as e:
        log(f"Email send failed: {e}")
        return False

def generate_booking_url(campground_id, site_id, start_date, end_date):
    """Generate a direct Recreation.gov link to book the specific site."""
    arrive = start_date[:10]
    depart = end_date[:10]
    return f"https://www.recreation.gov/camping/campsites/{site_id}?arrive={arrive}&depart={depart}"

def update_heartbeat(success=True):
    """Update the heartbeat file with the current timestamp and status."""
    try:
        data = {
            'last_run': datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ"),
            'success': success
        }
        heartbeat_dir = os.path.dirname(HEARTBEAT_FILE)
        if heartbeat_dir:
            os.makedirs(heartbeat_dir, exist_ok=True)
        with open(HEARTBEAT_FILE, 'w') as f:
            json.dump(data, f)
    except Exception as e:
        log(f"Failed to update heartbeat: {e}")

def get_campground_list(params):
    """Resolve the list of campgrounds to check from parameters."""
    if 'preset' in params:
        preset_name = params['preset']
        if preset_name in PRESETS:
            return PRESETS[preset_name]
        else:
            log(f"Error: Unknown preset '{preset_name}'")
            sys.exit(1)
    elif 'campgroundIds' in params:
        ids = params['campgroundIds']
        if not isinstance(ids, list):
            log("Error: campgroundIds must be an array")
            sys.exit(1)
        return [{"id": cid, "name": str(cid)} for cid in ids]
    elif 'campgroundId' in params:
        cid = params['campgroundId']
        return [{"id": cid, "name": str(cid)}]
    else:
        log("Error: Missing required parameter (preset, campgroundIds, or campgroundId)")
        sys.exit(1)

def main():
    global TEST_MODE, FORCE_MODE, LOG_FILE, CACHE_FILE, HEARTBEAT_FILE, TELEGRAM_MOCK_FILE

    # Parse command line arguments
    parser = argparse.ArgumentParser(description='Recreation.gov campsite availability checker')
    parser.add_argument('--test', '--simulate', action='store_true', help='Run in test mode (skip real API, use fake data)')
    parser.add_argument('--force', action='store_true', help='Force sending notifications even if no change')
    args = parser.parse_args()

    TEST_MODE = args.test
    FORCE_MODE = args.force

    if TEST_MODE:
        test_dir = os.environ.get('RECREATION_CHECK_TEST_DIR')
        if not test_dir:
            test_dir = os.path.join(os.path.dirname(DEFAULT_CACHE_FILE), 'recreation-check-test')
        os.makedirs(test_dir, exist_ok=True)
        CACHE_FILE = os.path.join(test_dir, 'recreation-check-last-result.json')
        LOG_FILE = os.path.join(test_dir, 'notifications.log')
        TELEGRAM_MOCK_FILE = os.path.join(test_dir, 'telegram-mock.txt')
        HEARTBEAT_FILE = os.path.join(test_dir, 'heartbeat.json')
        log(f"Test mode enabled, using test dir: {test_dir}")

    # Read input JSON from stdin
    try:
        params = json.load(sys.stdin)
    except json.JSONDecodeError:
        print("Error: Invalid JSON parameters", file=sys.stderr)
        sys.exit(1)

    start_date = params.get('startDate')
    end_date = params.get('endDate')
    if not start_date or not end_date:
        print("Error: Missing required parameters (startDate, endDate)", file=sys.stderr)
        sys.exit(1)

    campgrounds = get_campground_list(params)
    if not campgrounds:
        print("Error: No campgrounds to check", file=sys.stderr)
        sys.exit(1)

    all_available = []
    errors = []
    for idx, cg in enumerate(campgrounds):
        cid = cg['id']
        cname = cg['name']
        try:
            avail_sites = check_campground_availability(cid, start_date, end_date, test_mode=TEST_MODE)
            for site in avail_sites:
                site['campground_id'] = cid
                site['campground_name'] = cname
                all_available.append(site)
        except Exception as e:
            err_msg = f"Failed to check campground {cid} ({cname}): {e}"
            log(err_msg)
            errors.append(err_msg)
        if idx < len(campgrounds) - 1 and not TEST_MODE:
            time.sleep(1)

    count = len(all_available)

    current_timestamp = datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")
    checked_ids = [str(cg['id']) for cg in campgrounds]
    checked_names = {str(cg['id']): cg['name'] for cg in campgrounds}

    current_result = {
        'campgroundIds': checked_ids,
        'campgroundNames': checked_names,
        'startDate': start_date[:10],
        'endDate': end_date[:10],
        'timestamp': current_timestamp,
        'availableSites': all_available,
        'hadAvailability': count > 0
    }

    # Ensure cache directory exists
    cache_dir = os.path.dirname(CACHE_FILE)
    os.makedirs(cache_dir, exist_ok=True)

    prev_cache = None
    if os.path.exists(CACHE_FILE):
        try:
            with open(CACHE_FILE, 'r') as f:
                prev_cache = json.load(f)
        except Exception as e:
            log(f"Failed to read cache: {e}")

    has_change = has_availability_changed(prev_cache, current_result)
    if FORCE_MODE and count > 0:
        has_change = True

    # Write current result to cache
    with open(CACHE_FILE, 'w') as f:
        json.dump(current_result, f)

    if count > 0:
        print(f"Found {count} available site(s) from {start_date[:10]} to {end_date[:10]} across monitored campgrounds:")
        by_campground = {}
        for site in all_available:
            cg_name = site['campground_name']
            if cg_name not in by_campground:
                by_campground[cg_name] = []
            by_campground[cg_name].append(site)
        for cg_name, sites in sorted(by_campground.items()):
            print(f"\n{cg_name}:")
            for site in sites:
                dates_str = ", ".join(site['available_dates'])
                print(f"- Site {site['site']} ({site['loop']}), {site['campsite_type']}: {dates_str}")
    else:
        print(f"No campsites available for any monitored campgrounds from {start_date[:10]} to {end_date[:10]}.")

    if has_change and count > 0:
        msg_lines = [f"AVAILABILITY FOUND: {count} site(s) available from {start_date[:10]} to {end_date[:10]}"]
        by_campground = {}
        for site in all_available:
            cg_name = site['campground_name']
            if cg_name not in by_campground:
                by_campground[cg_name] = []
            by_campground[cg_name].append(site)

        for cg_name, sites in sorted(by_campground.items()):
            msg_lines.append(f"\n{cg_name}:")
            for site in sites[:10]:
                dates_str = ", ".join(site['available_dates'])
                booking_url = generate_booking_url(site['campground_id'], site['campsite_id'], start_date, end_date)
                msg_lines.append(f"- Site {site['site']} ({site['loop']}): {dates_str}")
                msg_lines.append(f"  Book: {booking_url}")
            remaining = len(sites) - 10
            if remaining > 0:
                msg_lines.append(f"... and {remaining} more in {cg_name}")

        msg = "\n".join(msg_lines).strip()

        log_dir = os.path.dirname(LOG_FILE)
        os.makedirs(log_dir, exist_ok=True)
        with open(LOG_FILE, 'a') as f:
            f.write(f"[{datetime.utcnow().strftime('%Y-%m-%d %H:%M:%S')} UTC] {msg}\n")
        log(f"Notification sent: {msg.replace(chr(10), ' ')}")

        telegram_chat_id = os.environ.get('OPENCLAW_TELEGRAM_CHAT_ID') or '8755267864'
        telegram_bot_token = os.environ.get('OPENCLAW_TELEGRAM_BOT_TOKEN')
        if telegram_bot_token:
            if TEST_MODE:
                with open(TELEGRAM_MOCK_FILE, 'w') as f:
                    f.write(msg)
                log(f"[TEST MODE] Telegram mock message written to {TELEGRAM_MOCK_FILE}")
            else:
                try:
                    subprocess.run([
                        'curl', '-s', '-X', 'POST',
                        f'https://api.telegram.org/bot{telegram_bot_token}/sendMessage',
                        '-d', f'chat_id={telegram_chat_id}',
                        '-d', f'text={msg}',
                        '-d', 'parse_mode=plain'
                    ], check=False)
                    log("Telegram notification sent")
                except Exception as e:
                    log(f"Telegram send failed: {e}")
        else:
            log("Telegram bot token not configured, skipping Telegram notification")

        if os.environ.get('OPENCLAW_SMTP_HOST'):
            email_subject = f"Campsite Availability Found: {count} site(s) in {', '.join(checked_names.values())}"
            send_email(email_subject, msg)

        update_heartbeat(success=True)
    else:
        update_heartbeat(success=not bool(errors))

    if errors:
        sys.exit(1)
    else:
        sys.exit(0)

if __name__ == '__main__':
    main()
