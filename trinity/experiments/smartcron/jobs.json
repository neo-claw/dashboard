{
  "jobs": [
    {
      "id": "daily_summary_write_commit",
      "schedule": "45 6 * * *",
      "command": "python3 ~/.openclaw/workspace/trinity/experiments/smartcron/write_daily_summary.py",
      "requires_network": false,
      "concurrency_lock": "daily_summary"
    },
    {
      "id": "health_ping",
      "schedule": "*/30 * * * *",
      "health_check_url": "http://localhost:8080/health",
      "agent_message": "System health check: what needs attention?",
      "requires_network": false
    },
    {
      "id": "backup_notes",
      "schedule": "0 2 * * *",
      "command": "cp -r ~/.openclaw/workspace/memory /backup/memory_$(date +%Y%m%d)",
      "requires_network": false,
      "concurrency_lock": "backup"
    }
  ]
}